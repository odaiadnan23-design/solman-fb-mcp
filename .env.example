# Copy to .env and fill in for your SolMan Focused Build system. Do NOT commit .env.

# --- Target system ---
SOLMAN_HOST=your-solman-host.example.com   # SolMan Focused Build host (no scheme)
SOLMAN_PORT=44300
SAP_CLIENT=100
SAP_LANGUAGE=EN
# SOLMAN_CA_BUNDLE=/path/to/corporate-root.pem   # optional: enable TLS verification

# --- Focused Build config (landscape-specific) ---
SOLMAN_REQ_PROCESS_TYPE=S1BR               # requirement transaction type in your config
SOLDOC_DEFAULT_SCOPE=SAP_DEFAULT_SCOPE

# --- Defaults for create_requirement (get these via the list_lookup / soldoc tools) ---
SOLMAN_SOLUTION_ID=                        # SOLUTIONSet SolutionId
SOLMAN_BRANCH_ID=                          # branch id (SOLUTIONSet(..)/Branchs)
SOLMAN_OWNER_BP=                           # default owner Business Partner number
SOLMAN_OWNER_NAME=                         # default owner display name
SOLMAN_CATEGORY_ID=                        # mandatory category (CATEGORYSet CatId), e.g. a GxP flag
SOLMAN_TEAM_NAME=                          # requirements team name
SOLMAN_TEAM_BP=                            # requirements team BP number
SOLMAN_PLANNED_PROJECT=                    # default planned project (WPPROJECTSet Description)
SOLMAN_PLANNED_PROJECT_GUID=               # default planned project GUID

# --- Optional overrides (defaults derive from home dir) ---
# SOLMAN_COOKIE_FILE=%USERPROFILE%\.vsp\cookies-pm1.txt
# SOLMAN_EDGE_PROFILE=%USERPROFILE%\.vsp\pm1-edge-profile
